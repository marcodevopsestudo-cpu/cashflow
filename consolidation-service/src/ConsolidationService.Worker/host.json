{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "Default": "Information",
      "Host.Results": "Information",
      "Function": "Information"
    }
  },
  "extensions": {
    "serviceBus": {
      "prefetchCount": 0,
      "messageHandlerOptions": {
        "autoCompleteMessages": false,
        "maxConcurrentCalls": 8,
        "maxAutoLockRenewalDuration": "00:05:00"
      }
    }
  }
}
