    {
      "name": "create-transactions",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const accessToken = pm.collectionVariables.get(\"access_token\");\r",
              "\r",
              "for (let i = 0; i < 100; i++) {\r",
              "\r",
              "    const kind = Math.random() < 0.5 ? \"credit\" : \"debit\";\r",
              "\r",
              "    const amount = Number((Math.random() * 990 + 10).toFixed(2));\r",
              "    const correlationId = crypto.randomUUID();\r",
              "\r",
              "    const transactionDateUtc = new Date(\r",
              "        Date.now() - Math.random() * 30 * 24 * 60 * 60 * 1000\r",
              "    ).toISOString();\r",
              "\r",
              "    const payload = {\r",
              "        accountId: \"ACC-123456\",\r",
              "        kind: kind, // 👈 string agora\r",
              "        amount: amount,\r",
              "        currency: \"BRL\",\r",
              "        transactionDateUtc: \"2026-03-26T14:30:00Z\",\r",
              "        description: `Payment ${kind} ${Math.floor(Math.random() * 10000)}`,\r",
              "        correlationId: correlationId\r",
              "    };\r",
              "\r",
              "    pm.sendRequest({\r",
              "        url: \"https://func-cashflow-dev-tx.azurewebsites.net/api/transactions\",\r",
              "        method: \"POST\",\r",
              "        header: {\r",
              "            \"Authorization\": `Bearer ${accessToken}`,\r",
              "            \"Idempotency-Key\": crypto.randomUUID(),\r",
              "            \"Content-Type\": \"application/json\"\r",
              "        },\r",
              "        body: {\r",
              "            mode: \"raw\",\r",
              "            raw: JSON.stringify(payload)\r",
              "        }\r",
              "    }, function (err, res) {\r",
              "        if (err) {\r",
              "            console.log(\"Erro:\", err);\r",
              "            return;\r",
              "        }\r",
              "\r",
              "        console.log(\"Status:\", res.code);\r",
              "        console.log(\"Kind:\", kind);\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
